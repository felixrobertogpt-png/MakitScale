{
  "name": "makitscale-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute makitscale-db --local --file=./migrations/0001_init.sql",
