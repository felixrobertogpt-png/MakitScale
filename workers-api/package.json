  },
  "dependencies": {
    "hono": "^4.7.0",
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250327.0",
    "wrangler": "^4.14.0",
    "typescript": "^5.8.0"
  }
}
